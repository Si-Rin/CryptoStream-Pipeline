# Kafka KRaft cluster identity (must be a 22-char URL-safe base64 string)
# Generate one with: docker run --rm confluentinc/cp-kafka:7.6.0 kafka-storage random-uuid
CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Host advertised to external clients (your producer/consumer connect through this)
# Use "localhost" for local dev, or the host LAN IP for shared machine
KAFKA_EXTERNAL_HOST=localhost

# External ports for the 3 brokers (must NOT collide with each other on host)
KAFKA1_EXTERNAL_PORT=9092
KAFKA2_EXTERNAL_PORT=9093
KAFKA3_EXTERNAL_PORT=9094

# Bootstrap string used by Python producer / Spark consumer
KAFKA_BOOTSTRAP=localhost:9092,localhost:9093,localhost:9094

# Paths for Spark Structured Streaming - Bronze layer
BRONZE_PATH=./data/bronze/trades
BRONZE_CHECKPOINT=./data/_chk/bronze

# Paths for Spark Structured Streaming - Silver layer
SILVER_PATH=./data/silver/ohlcv_1m
SILVER_CHECKPOINT=./data/_chk/silver